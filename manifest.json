{
  "manifest_version": 3,
  "name": "Freshworks organic UTM builder",
  "version": "1.0",
  "description": "Builds specific UTM URLs for organic social campaigns.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Freshworks UTM Builder"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "storage"
  ]
}